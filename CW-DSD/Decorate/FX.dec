actor CWDM_dustCloud : FXBase
{
	alpha 0.5
	renderStyle translucent
	scale 0.5
	States
	{
	Spawn:
		DUST AAAAA 5 A_fadeout(0.1)
		Stop
	}
}

actor CWDM_telefog : TeleportFog replaces TeleportFog
{
	RenderStyle "Add"
	Alpha 0.75
	States
	{
	Spawn:
		TLPT ABCDEFGHIJKLM 2 Bright
		stop
	}
}

actor CWDM_WaterSplash : FXBase
{
	States
	{
	Spawn:
		SPLS ABCDEFGHI 2
		Stop
	}
}