actor boomBarrel : Decoration 16128
{
//$Category Decoration
//$Title "Explosive Barrel"
//$Sprite BAR1A0
	Health 100
	Radius 16
	Height 42
    +SOLID
	+SHOOTABLE
	+NOBLOOD
	+DONTGIB
	+NOICEDEATH
	+FORCEPAIN
	+EXTREMEDEATH
	-INVULNERABLE
	+ALWAYSRESPAWN
	States
	{
	Spawn:
		BAR1 A -1
		Stop
	Death:
		BAR1 A 2
		//TNT1 A 0 A_QuakeEX(0, 0, 6, 35, 0, 512, "", QF_SCALEDOWN|QF_WAVE|QF_FULLINTENSITY|QF_3D, 0, 0, 15, 256, 0)
        TNT1 A 0 A_Quake(3, 4, 0, 1024, "dsnone")
        TNT1 A 0 A_Quake(2, 8, 0, 1024, "dsnone")
        TNT1 A 0 A_Quake(1, 12, 0, 1024, "dsnone")
		TNT1 A 0 A_PlaySound("misc/explode", CHAN_AUTO, 1.0, 0)
		TNT1 A 0 A_SpawnItemEX("CWDM_explosion")
		//TNT1 A 0 A_Explode(128, 192, XF_HURTSOURCE|XF_EXPLICITDAMAGETYPE, damagetype: "ExplosiveDamage")
		TNT1 A 0 A_Explode(128, 192)
		TNT1 A 35 
		Stop
	}
}

