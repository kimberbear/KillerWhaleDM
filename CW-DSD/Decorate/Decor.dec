actor Decoration 
{
	+SOLID
	yScale 1.098
}

actor Oak1 : Decoration 16125
{
//$Category Decoration
//$Title "Oak Tree 1"
//$Sprite OAK1A0
    Radius 32
    Height 223
    ProjectilePassHeight -16
    +SOLID
	States
	{
	Spawn:
	OAK1 A -1
	Stop
	}
}

