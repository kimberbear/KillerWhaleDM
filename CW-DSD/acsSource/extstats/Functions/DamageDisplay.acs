	CreateTranslation(DamDarkGray, 0:255=%[0,0,0]:[0.50, 0.50, 0.50]);
	CreateTranslation(DamCyan, 0:255=%[0,0,0]:[0.00, 0.85, 0.85]);
}

Script "ExtStats_SpawnDamageDisplay" (int x, int y, int z, int damage) CLIENTSIDE {
	int cpn = ConsolePlayerNumber();
	if(GetUserCVar(cpn, "exst_damageDisplay") && damage > 0) {
		int mode = GetUserCVar(cpn, "exst_damageDisplayVel");
		int option = GetUserCVar(cpn, "exst_dsd_damageDisplayMode");
		int _max = 1;
		if(damage >= 10000) _max = 5;
		else if(damage >= 1000) _max = 4;
		else if(damage >= 100) _max = 3;
		else if(damage >= 10) _max = 2;
		int var = GetUserCVar(cpn, "exst_damageDisplayCol");
		int col = var + DamBrick;
		if (var == -1)
			col = random(DamBrick, DamDarkRed);
		
		int velX = random(-0.25, 0.25);
		int velY = random(-0.25, 0.25);
		int velZ = 0.25;
		int thr = random(-4, -2);
		
		switch(mode) {
			case 1: // toss
				int posDiffY = GetActorY(0) - y;
				int posDiffX = GetActorX(0) - x;
				int ang = ((atan2(posDiffY, posDiffX) + 360.0) % 360.0) + (random(-5, 5) * 0.15);
				velY = sin(ang);
				velX = cos(ang);
				velZ = random(3, 4) * 0.25;
			break;
		}
		
		//int scale = GetUserCVar(cpn, "exst_damageDisplayScale");
		//int scaleMul = (_max * scale);
		for(int i = 1; i <= _max; i++) {
			int pos = _max - i;
			if(pos < 0) pos = 0;
			if(_max == 1) pos = 0;
			int digit = GetDigit(damage, pos);
			//Log(i:pos, s: " - digit ", i:digit);
			
			str actor = StrParam(s:"ExtStats_DamageDisplay_", s:DamageDisplay_Names[option], s:"_", i:_max);
			int u = UniqueTID();
			SpawnForced(actor, x, y, z, u);
			SetActivator(u);
			SetUserVariable(0, "user_digitThr", thr);
			
			/*
			if(scale > 0.0) {
				int newScale = scaleMul;
				SetActorProperty(u, APROP_ScaleX, GetActorProperty(u, APROP_ScaleX) * (newScale));
				SetActorProperty(u, APROP_ScaleY, GetActorProperty(u, APROP_ScaleY) * (newScale));
			}
			*/
			SetActorVelocity(0, velX, velY, velZ, 0, 0);
			Thing_SetTranslation(0, col);
			SetActorState(0, StrParam(s:"Spr",i:pos+1),1);
			SetActorState(0, StrParam(s:"Digit",i:digit),0);
		}
	}
}