#define MAX_DISPLAY 4
str DamageDisplay_Names[MAX_DISPLAY] = {
	"Big",
	"Small",
	"Flat",
	"Giant",
};

Script "ExtStats_DamageDisplay" (int type, int arg1, int arg2) EVENT
{
	If(type == GAMEEVENT_ACTOR_DAMAGED)
	{
		bool isPlayer = false;
		bool isExplosion = false;
		
		int damage = arg1;
		int damageProp = GetActorProperty(0, APROP_Damage) << 16;
		str damageType = arg2;
		SetActivator(0, AAPTR_DAMAGE_INFLICTOR);
		//Log(s:"Damage ",	i:damageProp);
		//Log(s:"Arg1 ",		i:damage);
		if(damage > 10000) { //max digits supported
			damage = 9999;
		}
		
		SetUserVariable(0, "user_damageDisplayExemptProj", 1);
		If(GetUserVariable(0, "user_damageDisplayExemptProj")) Terminate;
		
		If( (round(damageProp) != round(damage) && ClassifyActor(0) & ACTOR_MISSILE) ||
		(damageType == MOD_R_SPLASH || damageType == MOD_BARREL ) ) {
			isExplosion = true; // not sure how to do this properly. whatever.
		}
		
		// Check if player
		SetActivator(0, AAPTR_DAMAGE_SOURCE);
		If(ClassifyActor(0) & ACTOR_PLAYER) {
			isPlayer = true;
			int num = PlayerNumber();
			str weapon = GetWeaponName();
		}
		
		SetActivator(0, AAPTR_DAMAGE_TARGET);
		SetUserVariable(0, "user_damageDisplayExemptMonst", 1);
		If(GetUserVariable(0, "user_damageDisplayExemptMonst")) Terminate;
		// Actor is probably dead, store the stats for the player if possible.
		If(GetActorProperty(0, APROP_Health) - damage <= 0 && isPlayer) {
			if(GetGameModeState() == GAMESTATE_INPROGRESS)
				TrackWeapon(num, weapon);
		}
		
		// Now spawn the damage display
		int x = GetActorX(0) + random(-10.0, 10.0);
		int y = GetActorY(0) + random(-10.0, 10.0);
		int z = GetActorZ(0) + GetActorProperty(0, APROP_HEIGHT) + random(-10.0, 10.0);
		int angle = GetActorAngle(0);
		
		ACS_NamedExecuteWithResult("ExtStats_SpawnDamageDisplay", x, y, z, damage);
	}
}

