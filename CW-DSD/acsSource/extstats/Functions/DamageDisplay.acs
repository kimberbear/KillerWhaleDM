// [Binary] Shows damage popups on hit, not much else to it.
// (besides the stat tracker)
Function Int abs(Int val) {
	Return val < 0 ? -val : val;
}

Function Int atan(Int x)
{
	Return VectorAngle(1.0, x);
}
Function Int atan2(Int y, int x)
{
	Return VectorAngle(y, x);
}

Function Int GetDigit(Int number, Int position) {
	Int divisor = 1;
	For (Int i = 0; i < position; i++) {
		divisor *= 10;
	}
	Return (number / divisor) % 10;
}
Function Str GetWeaponName(Void)
{
	str wepActor = GetWeapon();
	int u = UniqueTID();
	SpawnForced(wepActor, 0, 0, 0, u, 0);
	str res = GetActorProperty(u, Aprop_NameTag);
	Thing_Remove(u);
	return res;
}

